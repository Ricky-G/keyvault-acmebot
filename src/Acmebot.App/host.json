{
  "version": "2.0",
  "telemetryMode": "OpenTelemetry",
  "logging": {
    "logLevel": {
      "default": "Warning"
    }
  },
  "extensions": {
    "durableTask": {
      "storageProvider": {
        "maxQueuePollingInterval": "00:00:30"
      },
      "tracing": {
        "distributedTracingEnabled": true,
        "version": "V2"
      }
    },
    "http": {
      "routePrefix": "",
      "customHeaders": {
        "Cache-Control": "no-store"
      }
    }
  }
}
